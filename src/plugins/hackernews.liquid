<div class="view view--full">
  <div class="layout">
    {% if stories.size == 0 %}
      <div style="height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;">
        <span class="value value--large">No stories</span>
        <span class="label">Nothing in the last 24 hours</span>
      </div>
    {% else %}
      <div style="display:flex; flex-direction:column; height:100%; width:100%;">
        {% for s in stories %}
          <div style="flex:1 1 0; display:flex; align-items:center; gap:14px; padding:0 2px;{% unless forloop.last %} border-bottom:1px solid #ccc;{% endunless %}">
            {% comment %} Rank: a light anchor in the left gutter (replaces the old QR column) {% endcomment %}
            <div style="flex:0 0 30px; text-align:center;">
              <span style="font-size:30px; font-weight:700; color:#bbb; line-height:1;">{{ forloop.index }}</span>
            </div>

            {% comment %} Three visual tiers: bold title → muted summary → small light metadata {% endcomment %}
            <div style="flex:1 1 auto; min-width:0; display:flex; flex-direction:column; gap:3px;">
              <span style="font-size:21px; font-weight:700; line-height:1.1; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">{{ s.title }}</span>

              {% if s.summary != "" %}
                <span style="font-size:15px; font-weight:400; line-height:1.22; color:#555; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">{{ s.summary }}</span>
              {% endif %}

              <span style="font-size:13px; font-weight:400; line-height:1; color:#888; letter-spacing:0.2px;">{{ s.points }} pts &nbsp;&middot;&nbsp; {{ s.comments }} comments &nbsp;&middot;&nbsp; {{ s.domain }} &nbsp;&middot;&nbsp; {{ s.author }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="title_bar">
    <span class="title">Hacker News</span>
    <span class="instance">Top of the last 24h &middot; {{ updated_at }}</span>
  </div>
</div>
