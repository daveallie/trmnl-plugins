<div class="view view--full">
  <div class="layout">
    {% if stories.size == 0 %}
      <div style="height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;">
        <span class="value value--large">No stories</span>
        <span class="label">Nothing in the last 24 hours</span>
      </div>
    {% else %}
      <div style="display:flex; flex-direction:column; height:100%; width:100%;">
        {% for s in stories %}
          <div style="flex:1 1 0; display:flex; align-items:center; gap:16px; padding:0 6px;{% unless forloop.last %} border-bottom:2px dashed #555;{% endunless %}">
            {% comment %} Scan-to-open QR for the HN discussion {% endcomment %}
            <div style="flex:0 0 auto; width:64px; height:64px;">
              <img src="{{ s.qr }}" alt="QR" style="width:64px; height:64px; image-rendering:pixelated;" />
            </div>

            {% comment %} Title, AI summary, metadata {% endcomment %}
            <div style="flex:1 1 auto; min-width:0;">
              <span class="title title--small" style="display:block; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">{{ s.title }}</span>
              {% if s.summary != "" %}
                <span class="label" style="display:block; overflow:hidden; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical;">{{ s.summary }}</span>
              {% endif %}
              <span class="label" style="display:block; font-weight:700;">{{ s.points }} pts &middot; {{ s.comments }} comments &middot; {{ s.domain }} &middot; by {{ s.author }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="title_bar">
    <span class="title">Hacker News</span>
    <span class="instance">Top of the last 24h &middot; {{ updated_at }}</span>
  </div>
</div>
