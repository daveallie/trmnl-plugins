<div class="view view--full">
  <div class="layout">
    {% if stories.size == 0 %}
      <div style="height:100%; display:flex; flex-direction:column; align-items:center; justify-content:center; gap:6px;">
        <span class="value value--large">No stories</span>
        <span class="label">Nothing in the last 24 hours</span>
      </div>
    {% else %}
      {% comment %} Rows distribute evenly over the fixed height; hierarchy comes
      from weight + size (black throughout) so it survives 1-bit dithering. {% endcomment %}
      <div style="display:flex; flex-direction:column; height:100%; width:100%;">
        {% for s in stories %}
          <div class="item" style="flex:1 1 0; min-height:0; align-items:center; overflow:hidden;{% unless forloop.last %} border-bottom:1px solid #000;{% endunless %}">
            <div class="meta">
              <span class="index">{{ forloop.index }}</span>
            </div>
            <div class="content">
              <span class="title title--small" style="overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">{{ s.title }}</span>
              {% if s.summary != "" %}
                <span class="description" data-clamp="2">{{ s.summary }}</span>
              {% endif %}
              <span class="label label--small" style="overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">{{ s.points }} pts &middot; {{ s.comments }} comments &middot; {{ s.domain }} &middot; {{ s.author }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>

  <div class="title_bar">
    <span class="title">Hacker News</span>
    <span class="instance">Top of the last 24h &middot; {{ updated_at }}</span>
  </div>
</div>
