{% comment %} 1-bit SVG weather glyphs, selected by icon key {% endcomment %}
{% capture icon_clear %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2"><circle cx="12" cy="12" r="5"/><g stroke-linecap="round"><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4" y1="4" x2="5.5" y2="5.5"/><line x1="18.5" y1="18.5" x2="20" y2="20"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4" y1="20" x2="5.5" y2="18.5"/><line x1="18.5" y1="5.5" x2="20" y2="4"/></g></svg>{% endcapture %}
{% capture icon_partly %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2"><circle cx="8" cy="8" r="3.5"/><path d="M7 18h10a4 4 0 0 0 0-8 5 5 0 0 0-9.5-1.5"/></svg>{% endcapture %}
{% capture icon_cloudy %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2"><path d="M7 18h10a4 4 0 0 0 0-8 5.5 5.5 0 0 0-10.5 1.5A3.5 3.5 0 0 0 7 18z"/></svg>{% endcapture %}
{% capture icon_fog %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M6 9h10a4 4 0 0 0-8-1.5"/><line x1="3" y1="15" x2="21" y2="15"/><line x1="5" y1="19" x2="19" y2="19"/></svg>{% endcapture %}
{% capture icon_drizzle %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M7 15h10a4 4 0 0 0 0-8 5.5 5.5 0 0 0-10.5 1.5A3.5 3.5 0 0 0 7 15z"/><line x1="9" y1="19" x2="9" y2="21"/><line x1="15" y1="19" x2="15" y2="21"/></svg>{% endcapture %}
{% capture icon_rain %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M7 14h10a4 4 0 0 0 0-8 5.5 5.5 0 0 0-10.5 1.5A3.5 3.5 0 0 0 7 14z"/><line x1="8" y1="18" x2="7" y2="22"/><line x1="13" y1="18" x2="12" y2="22"/><line x1="18" y1="18" x2="17" y2="22"/></svg>{% endcapture %}
{% capture icon_snow %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round"><path d="M7 14h10a4 4 0 0 0 0-8 5.5 5.5 0 0 0-10.5 1.5A3.5 3.5 0 0 0 7 14z"/><circle cx="8" cy="19" r="1" fill="#000" stroke="none"/><circle cx="12" cy="21" r="1" fill="#000" stroke="none"/><circle cx="16" cy="19" r="1" fill="#000" stroke="none"/></svg>{% endcapture %}
{% capture icon_thunder %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linejoin="round" stroke-linecap="round"><path d="M7 13h10a4 4 0 0 0 0-8 5.5 5.5 0 0 0-10.5 1.5A3.5 3.5 0 0 0 7 13z"/><path d="M12 14l-3 4h3l-1 4 4-5h-3z" fill="#000"/></svg>{% endcapture %}

{% comment %} Pick a glyph by icon key {% endcomment %}
{% capture current_icon %}{% case current.icon %}{% when 'clear' %}{{ icon_clear }}{% when 'partly' %}{{ icon_partly }}{% when 'fog' %}{{ icon_fog }}{% when 'drizzle' %}{{ icon_drizzle }}{% when 'rain' %}{{ icon_rain }}{% when 'snow' %}{{ icon_snow }}{% when 'thunder' %}{{ icon_thunder }}{% else %}{{ icon_cloudy }}{% endcase %}{% endcapture %}

<div class="view view--full">
  <div class="layout" style="display:flex; gap:24px; height:100%;">

    {% comment %} Left: current conditions {% endcomment %}
    <div style="flex:0 0 230px; display:flex; flex-direction:column; gap:10px;">
      <div style="display:flex; align-items:center; gap:14px;">
        <div style="width:64px; height:64px; flex:0 0 auto;">{{ current_icon }}</div>
        <div>
          <span class="value value--large" style="line-height:1;">{{ current.temp }}&deg;</span>
          <span class="label" style="display:block;">{{ current.label }}</span>
        </div>
      </div>
      <div style="display:flex; flex-direction:column; gap:6px; margin-top:6px;">
        <span class="label">Feels like {{ current.feelsLike }}&deg;</span>
        <span class="label">Wind {{ current.wind.speed }} km/h {{ current.wind.direction }}</span>
        <span class="label">Sunrise {{ sunrise }} &middot; Sunset {{ sunset }}</span>
      </div>
    </div>

    {% comment %} Right: rain timeline + 7-day outlook {% endcomment %}
    <div style="flex:1 1 0; min-width:0; display:flex; flex-direction:column; gap:16px;">

      {% comment %} Next 12 hours of rain chance {% endcomment %}
      <div>
        <span class="label" style="display:block; margin-bottom:4px;">Rain &mdash; next 12h</span>
        <div style="display:flex; align-items:flex-end; gap:4px; height:96px;">
          {% for h in hourly %}
            <div style="flex:1 1 0; display:flex; flex-direction:column; align-items:center; justify-content:flex-end; height:100%;">
              <span style="font-size:11px;">{{ h.chance }}</span>
              <div style="width:100%; height:54px; display:flex; align-items:flex-end; border-bottom:2px solid #000;">
                <div style="width:100%; height:{{ h.chance }}%; background:#000;"></div>
              </div>
              <span style="font-size:10px; margin-top:2px;">{{ h.hour }}</span>
            </div>
          {% endfor %}
        </div>
      </div>

      {% comment %} 7-day outlook {% endcomment %}
      <div style="flex:1 1 0; display:flex; flex-direction:column;">
        {% for d in daily %}
          <div style="flex:1 1 0; display:flex; align-items:center; gap:12px; padding:0 2px;{% unless forloop.last %} border-bottom:1px dashed #555;{% endunless %}">
            <span class="label" style="flex:0 0 54px; font-weight:700;">{{ d.day }}</span>
            <div style="flex:0 0 22px; height:22px;">{% case d.icon %}{% when 'clear' %}{{ icon_clear }}{% when 'partly' %}{{ icon_partly }}{% when 'fog' %}{{ icon_fog }}{% when 'drizzle' %}{{ icon_drizzle }}{% when 'rain' %}{{ icon_rain }}{% when 'snow' %}{{ icon_snow }}{% when 'thunder' %}{{ icon_thunder }}{% else %}{{ icon_cloudy }}{% endcase %}</div>
            <span class="label" style="flex:0 0 56px;">{{ d.chance }}% rain</span>
            <span class="label" style="flex:1 1 0; text-align:right;">{{ d.high }}&deg; / {{ d.low }}&deg;</span>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="title_bar">
    <span class="title">Weather</span>
    <span class="instance">{{ location }} &middot; {{ updated_at }}</span>
  </div>
</div>
