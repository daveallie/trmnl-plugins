{% comment %} 1-bit stroke glyphs (Feather-style), selected by icon key {% endcomment %}
{% capture icon_clear %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>{% endcapture %}
{% capture icon_partly %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="7.5" cy="7" r="2.6"/><line x1="7.5" y1="1.8" x2="7.5" y2="3.1"/><line x1="2.3" y1="7" x2="3.6" y2="7"/><line x1="3.8" y1="3.3" x2="4.7" y2="4.2"/><line x1="11.2" y1="3.3" x2="10.3" y2="4.2"/><g transform="translate(2.5,4.5) scale(0.74)"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></g></svg>{% endcapture %}
{% capture icon_cloudy %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 10h-1.26A8 8 0 1 0 9 20h9a5 5 0 0 0 0-10z"/></svg>{% endcapture %}
{% capture icon_fog %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="8" x2="21" y2="8"/><line x1="5" y1="12" x2="19" y2="12"/><line x1="4" y1="16" x2="20" y2="16"/><line x1="7" y1="20" x2="17" y2="20"/></svg>{% endcapture %}
{% capture icon_drizzle %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16.58A5 5 0 0 0 18 7h-1.26A8 8 0 1 0 4 15.25"/><line x1="8" y1="19" x2="8" y2="21"/><line x1="12" y1="20" x2="12" y2="22"/><line x1="16" y1="19" x2="16" y2="21"/></svg>{% endcapture %}
{% capture icon_rain %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16.58A5 5 0 0 0 18 7h-1.26A8 8 0 1 0 4 15.25"/><line x1="8" y1="19" x2="8" y2="23"/><line x1="12" y1="20" x2="12" y2="24"/><line x1="16" y1="19" x2="16" y2="23"/></svg>{% endcapture %}
{% capture icon_snow %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 16.58A5 5 0 0 0 18 7h-1.26A8 8 0 1 0 4 15.25"/><line x1="8" y1="19" x2="8.01" y2="19"/><line x1="12" y1="21" x2="12.01" y2="21"/><line x1="16" y1="19" x2="16.01" y2="19"/></svg>{% endcapture %}
{% capture icon_thunder %}<svg viewBox="0 0 24 24" width="100%" height="100%" fill="none" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 16.9A5 5 0 0 0 18 7h-1.26a8 8 0 1 0-11.62 9"/><polyline points="13 11 9 17 15 17 11 23"/></svg>{% endcapture %}

{% comment %} Map an icon key to its glyph {% endcomment %}
{% capture current_icon %}{% case current.icon %}{% when 'clear' %}{{ icon_clear }}{% when 'partly' %}{{ icon_partly }}{% when 'fog' %}{{ icon_fog }}{% when 'drizzle' %}{{ icon_drizzle }}{% when 'rain' %}{{ icon_rain }}{% when 'snow' %}{{ icon_snow }}{% when 'thunder' %}{{ icon_thunder }}{% else %}{{ icon_cloudy }}{% endcase %}{% endcapture %}

<div class="view view--full">
  <div class="layout" style="display:flex; height:100%; gap:0;">

    {% comment %} Left: current conditions, fills column height {% endcomment %}
    <div style="flex:0 0 244px; display:flex; flex-direction:column; padding-right:22px; border-right:3px solid #000;">
      <div style="display:flex; align-items:center; gap:12px;">
        <div style="width:74px; height:74px; flex:0 0 auto;">{{ current_icon }}</div>
        <div style="min-width:0;">
          <span class="value value--xxlarge" style="line-height:0.9;">{{ current.temp }}&deg;</span>
        </div>
      </div>
      <span class="title title--small" style="margin-top:6px;">{{ current.label }}</span>

      <div style="margin-top:34px; display:flex; flex-direction:column; gap:14px;">
        <div style="display:flex; justify-content:space-between; align-items:baseline;">
          <span class="label">Feels like</span>
          <span class="value value--small">{{ current.feelsLike }}&deg;</span>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:baseline;">
          <span class="label">Wind</span>
          <span class="value value--small">{{ current.wind.speed }} km/h {{ current.wind.direction }}</span>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:baseline;">
          <span class="label">Sunrise</span>
          <span class="value value--small">{{ sunrise }}</span>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:baseline;">
          <span class="label">Sunset</span>
          <span class="value value--small">{{ sunset }}</span>
        </div>
      </div>
    </div>

    {% comment %} Right: rain timeline + 7-day outlook {% endcomment %}
    <div style="flex:1 1 0; min-width:0; display:flex; flex-direction:column; padding-left:22px;">

      {% comment %} Next 12 hours of rain chance {% endcomment %}
      <div style="flex:0 0 auto;">
        <span class="label label--small" style="display:block; margin-bottom:6px; font-weight:700;">CHANCE OF RAIN &middot; NEXT 12H</span>
        <div style="display:flex; align-items:flex-end; gap:5px;">
          {% for h in hourly %}
            <div style="flex:1 1 0; display:flex; flex-direction:column; align-items:center;">
              <span style="font-size:13px; line-height:1; margin-bottom:3px;">{{ h.chance }}</span>
              <div style="position:relative; width:100%; height:60px; border:1.5px solid #000; border-radius:2px;">
                <div style="position:absolute; left:0; right:0; bottom:0; height:{{ h.chance }}%; background:#000;"></div>
              </div>
              <span style="font-size:11px; line-height:1; margin-top:4px;">{{ h.hour }}</span>
            </div>
          {% else %}
            <span class="label">No hourly data</span>
          {% endfor %}
        </div>
      </div>

      {% comment %} 7-day outlook, fills remaining height {% endcomment %}
      <div style="flex:1 1 0; display:flex; flex-direction:column; margin-top:14px; border-top:3px solid #000;">
        {% for d in daily %}
          <div style="flex:1 1 0; display:flex; align-items:center; gap:12px;{% unless forloop.last %} border-bottom:1px solid #000;{% endunless %}">
            <div style="flex:0 0 28px; height:28px;">{% case d.icon %}{% when 'clear' %}{{ icon_clear }}{% when 'partly' %}{{ icon_partly }}{% when 'fog' %}{{ icon_fog }}{% when 'drizzle' %}{{ icon_drizzle }}{% when 'rain' %}{{ icon_rain }}{% when 'snow' %}{{ icon_snow }}{% when 'thunder' %}{{ icon_thunder }}{% else %}{{ icon_cloudy }}{% endcase %}</div>
            <span class="value value--small" style="flex:0 0 68px;">{{ d.day }}</span>
            <span class="value value--small" style="flex:0 0 48px; text-align:right;">{{ d.chance }}%</span>
            <span class="label" style="flex:0 0 auto;">rain</span>
            <span class="value value--small" style="flex:1 1 0; text-align:right; white-space:nowrap;">
              <span style="display:inline-block; width:46px; text-align:right;">{{ d.low }}&deg;</span>
              <span class="label"> / </span>
              <span style="display:inline-block; width:46px; text-align:right;">{{ d.high }}&deg;</span>
            </span>
          </div>
        {% else %}
          <span class="label">No forecast available</span>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="title_bar">
    <span class="title">Weather</span>
    <span class="instance">{{ location }} &middot; {{ updated_at }}</span>
  </div>
</div>
