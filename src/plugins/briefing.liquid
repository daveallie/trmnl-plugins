<div class="view view--full">
  <div class="layout">
    <div style="display:flex; height:100%; width:100%; box-sizing:border-box;">

      {% comment %} Left column: blended news digest (world + tech), large text {% endcomment %}
      <div style="flex:1.2 1 0; min-width:0; box-sizing:border-box; padding-right:20px; border-right:3px solid #000; display:flex; flex-direction:column;">
        <span class="label label--small font--bold" style="display:block; margin-bottom:10px;">TODAY'S NEWS</span>
        {% if news %}
          <span class="description description--xlarge" style="display:block;">{{ news.digest }}</span>
        {% else %}
          <span class="label">News unavailable</span>
        {% endif %}
      </div>

      {% comment %} Right column: weather (large) over trams {% endcomment %}
      <div style="flex:1 1 0; min-width:0; box-sizing:border-box; display:flex; flex-direction:column; padding-left:20px;">

        {% comment %} Weather — enlarged {% endcomment %}
        <div style="flex:0 0 auto; padding-bottom:10px; border-bottom:2px solid #000;">
          <span class="label label--small font--bold" style="display:block; margin-bottom:4px;">WEATHER</span>
          {% if weather %}
            <span class="value value--base" style="display:block;">{{ weather.temp }}&deg; {{ weather.label }}</span>
            <span class="value value--base" style="display:block; margin-top:4px;">{{ weather.high }}&deg; / {{ weather.low }}&deg;</span>
            <span class="label label--base" style="display:block; margin-top:6px;">{{ weather.rainChance }}% rain{% if weather.rainMm > 0 %} &middot; {{ weather.rainMm }}mm{% endif %}</span>
            <div class="flex" style="gap:18px; margin-top:6px;">
              <span class="label label--base">&uarr; {{ weather.sunrise }}</span>
              <span class="label label--base">&darr; {{ weather.sunset }}</span>
            </div>
          {% else %}
            <span class="label">Weather unavailable</span>
          {% endif %}
        </div>

        {% comment %} Next trams — route number + time only {% endcomment %}
        <div style="flex:1 1 0; min-height:0; padding-top:10px;">
          <span class="label label--small font--bold" style="display:block; overflow:hidden; white-space:nowrap; text-overflow:ellipsis; margin-bottom:6px;">NEXT TRAMS{% if tram %} &middot; {{ tram.stopName }}{% endif %}</span>
          {% if tram %}
            {% if tram.departures.size == 0 %}
              <span class="label">No trams soon</span>
            {% else %}
              {% for d in tram.departures %}
                <div class="flex flex--between" style="align-items:baseline; margin-bottom:6px;">
                  <span class="value value--base shrink-0">{{ d.route }}</span>
                  <span class="value value--base value--tnums">{{ d.time }}</span>
                </div>
              {% endfor %}
            {% endif %}
          {% else %}
            <span class="label">Trams unavailable</span>
          {% endif %}
        </div>

      </div>
    </div>
  </div>

  <div class="title_bar">
    <span class="title">Daily Briefing</span>
    <span class="instance">{{ date }} &middot; Updated {{ updated_at }}</span>
  </div>
</div>
