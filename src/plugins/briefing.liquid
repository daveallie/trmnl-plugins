<div class="view view--full">
  <div class="layout" style="display:flex; flex-direction:column; gap:0;">

    {% comment %} Header bar: greeting + date + updated_at {% endcomment %}
    <div style="flex:0 0 auto; display:flex; justify-content:space-between; align-items:baseline; padding-bottom:8px; border-bottom:3px solid #000;">
      <span class="title">{{ greeting }}</span>
      <span class="label">{{ date }} &middot; {{ updated_at }}</span>
    </div>

    {% comment %} Body: wide left (agenda) + right column (weather + trams) {% endcomment %}
    <div style="flex:1 1 0; display:flex; min-height:0; padding:10px 0;">

      {% comment %} Left column: calendar agenda {% endcomment %}
      <div style="flex:1.3 1 0; min-width:0; padding-right:18px; border-right:3px solid #000;">
        <span class="label label--small font--bold" style="display:block; margin-bottom:8px;">TODAY</span>
        {% if agenda %}
          {% if agenda.events.size == 0 %}
            <span class="label">Nothing scheduled</span>
          {% else %}
            {% for e in agenda.events %}
              <div style="display:flex; gap:10px; align-items:baseline; margin-bottom:6px;">
                <span class="value value--small value--tnums" style="flex:0 0 76px;">{{ e.time }}</span>
                <span class="value value--small" style="flex:1 1 0; min-width:0; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">{{ e.title }}</span>
              </div>
            {% endfor %}
          {% endif %}
        {% else %}
          <span class="label">Calendar unavailable</span>
        {% endif %}
      </div>

      {% comment %} Right column: weather (top) + trams (bottom) {% endcomment %}
      <div style="flex:1 1 0; min-width:0; display:flex; flex-direction:column; padding-left:18px;">

        {% comment %} Weather strip {% endcomment %}
        <div style="flex:0 0 auto; padding-bottom:10px; border-bottom:2px solid #000;">
          <span class="label label--small font--bold" style="display:block; margin-bottom:4px;">WEATHER</span>
          {% if weather %}
            <span class="value value--large">{{ weather.temp }}&deg; {{ weather.label }}</span>
            <div style="display:flex; justify-content:space-between; align-items:baseline; margin-top:4px;">
              <span class="label">{{ weather.high }}&deg; / {{ weather.low }}&deg; &middot; {{ weather.rainChance }}% rain</span>
            </div>
            <div style="display:flex; justify-content:space-between; align-items:baseline; margin-top:2px;">
              <span class="label">&uarr; {{ weather.sunrise }}</span>
              <span class="label">&darr; {{ weather.sunset }}</span>
            </div>
          {% else %}
            <span class="label">Weather unavailable</span>
          {% endif %}
        </div>

        {% comment %} Trams strip {% endcomment %}
        <div style="flex:1 1 0; padding-top:10px;">
          <span class="label label--small font--bold" style="display:block; margin-bottom:6px;">
            NEXT TRAMS{% if tram %} &middot; {{ tram.stopName }}{% endif %}
          </span>
          {% if tram %}
            {% if tram.departures.size == 0 %}
              <span class="label">No trams soon</span>
            {% else %}
              {% for d in tram.departures %}
                <div style="display:flex; justify-content:space-between; align-items:baseline; margin-bottom:5px;">
                  <span class="value value--small" style="flex:1 1 0; min-width:0; overflow:hidden; white-space:nowrap; text-overflow:ellipsis;">{{ d.route }} &rarr; {{ d.destination }}</span>
                  <span class="value value--small value--tnums" style="flex:0 0 auto; padding-left:8px;">{{ d.time }}</span>
                </div>
              {% endfor %}
            {% endif %}
          {% else %}
            <span class="label">Trams unavailable</span>
          {% endif %}
        </div>

      </div>
    </div>

    {% comment %} News digest strip (full width) {% endcomment %}
    <div style="flex:0 0 auto; padding-top:8px; border-top:3px solid #000;">
      <span class="label label--small font--bold">TECH TODAY</span>
      {% if news %}
        <span class="description" data-clamp="2" style="display:block; margin-top:3px;">{{ news.digest }}</span>
      {% else %}
        <span class="label">News unavailable</span>
      {% endif %}
    </div>

  </div>

  <div class="title_bar">
    <span class="title">Daily Briefing</span>
    <span class="instance">Updated {{ updated_at }}</span>
  </div>
</div>
